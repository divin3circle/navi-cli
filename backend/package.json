{
  "name": "@genssh/backend",
  "version": "1.0.0",
  "description": "GenSSH WebSocket Relay Server - bridges the web dashboard to the local CLI agent",
  "type": "module",
  "private": true,
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
